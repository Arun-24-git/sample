    if request.method == 'POST':
        staff_name = request.form['staff_name'].strip()
        phone = request.form['phone'].strip()
        username = request.form['username'].strip()
        password = request.form['password']
        errors = []
        if not re.match(r"^[a-zA-Z\s]{2,50}$", staff_name): errors.append("Full Name must be 2-50 characters.")
        if not re.match(r"^\d{10,13}$", phone): errors.append("Phone Number must be 10-13 digits.")
