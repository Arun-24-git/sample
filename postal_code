@app.route('/staff/finalize_and_sort', methods=['POST'])
@login_required
@role_required('staff')
def finalize_and_sort():
    data = request.get_json()
    parcels_data = data.get('parcels')
    staff_id = session.get('staff_id')

    if not parcels_data:
        return jsonify({'success': False, 'message': 'No parcel data provided.'}), 400

    conn = get_db_connection()
    if not conn:
        return jsonify({'success': False, 'message': 'Database service is unavailable.'}), 500

    cursor = conn.cursor(dictionary=True)
    
    try:
        cursor.execute("SELECT bin_id, pin FROM bin")
        bins_map_for_db = {str(bin_rule['pin']): bin_rule['bin_id'] for bin_rule in cursor.fetchall()}
    except Error as e:
        cursor.close()
        conn.close()
        print(f"Error fetching bin map: {e}") # Log error
        return jsonify({'success': False, 'message': f'Could not fetch bin rules: {e}'}), 500

    # The entire batch of parcels will be processed in a single database transaction.
    # This is much safer and more reliable.
    try:
        # Loop through all parcels and perform the database insertions.
        for parcel in parcels_data:
            image_path = parcel.get('image_path')
            raw_pincode_str = parcel.get('pincode')
            address = parcel.get('address')
            
            pincode_str = raw_pincode_str.strip() if raw_pincode_str else ""
            
            is_sortable = pincode_str and pincode_str in bins_map_for_db
            parcel_status = 'binned' if is_sortable else 'unsortable'
            
            sql_insert_parcel = "INSERT INTO parcel (image_path, staff_id, pincode, full_address, status) VALUES (%s, %s, %s, %s, %s)"
            cursor.execute(sql_insert_parcel, (image_path, staff_id, pincode_str or None, address, parcel_status))
            new_parcel_id = cursor.lastrowid

            if is_sortable:
                bin_id = bins_map_for_db[pincode_str]
                cursor.execute("INSERT INTO sorted_item (parcel_id, staff_id, bin_id) VALUES (%s, %s, %s)", (new_parcel_id, staff_id, bin_id))

        # If the loop completes without any errors, commit all changes to the database.
        conn.commit()

    except Error as e:
        # If any error occurs during the loop, roll back all changes from this batch.
        conn.rollback()
        print(f"DATABASE TRANSACTION FAILED: {e}") # Log the specific error
    
    finally:
        # Always close the cursor and connection.
        cursor.close()
        conn.close()

    session['parcels_data'] = parcels_data
    session['bins_map'] = bins_map_for_db

    return jsonify({'success': True, 'redirect_url': url_for('sorting_animation')})


# --- PDF Helper Class and Other Staff Routes ---
class PDF(FPDF):
    def header(self):
        self.set_font('Arial', 'B', 14)
        self.cell(0, 10, 'PostalAI Bin Manifest', 0, 1, 'C')
        self.ln(5)
    def footer(self):
        self.set_y(-15)
        self.set_font('Arial', 'I', 8)
        self.cell(0, 10, f'Page {self.page_no()}', 0, 0, 'C')
    def create_table(self, data, bin_name):
        self.set_font('Arial', 'B', 12)
        self.cell(0, 10, f'Contents for: {bin_name}', 0, 1, 'L')
        self.ln(5)
        col_widths = [15, 125, 40]
        headers = ['SL. NO', 'Address', 'Pincode']
        line_height = 8
        self.set_font('Arial', 'B', 10)
        for i, header in enumerate(headers):
            self.cell(col_widths[i], 10, header, 1, 0, 'C')
        self.ln()
        self.set_font('Arial', '', 10)
        if not data:
            self.cell(sum(col_widths), 10, 'This bin is currently empty.', 1, 1, 'C')
        else:
            for i, row in enumerate(data):
                sl_no_text = str(i + 1)
                address_text = str(row.get('full_address', 'N/A'))
                pincode_text = str(row.get('pincode', 'N/A'))
                words = address_text.split(' ')
                lines = ['']
                for word in words:
                    current_line = lines[-1]
                    if self.get_string_width(current_line + ' ' + word) < col_widths[1] - 4:
                        lines[-1] += ' ' + word
                    else:
                        lines.append(word)
                lines = [line.strip() for line in lines]
                num_lines = len(lines)
                row_height = max(line_height, num_lines * line_height)
                if self.get_y() + row_height > self.page_break_trigger:
                    self.add_page(self.cur_orientation)
                    self.set_font('Arial', 'B', 10)
                    for k, header in enumerate(headers):
                        self.cell(col_widths[k], 10, header, 1, 0, 'C')
                    self.ln()
                    self.set_font('Arial', '', 10)
                x_start = self.get_x()
                y_start = self.get_y()
                self.rect(x_start, y_start, col_widths[0], row_height)
                self.rect(x_start + col_widths[0], y_start, col_widths[1], row_height)
                self.rect(x_start + col_widths[0] + col_widths[1], y_start, col_widths[2], row_height)
                sl_no_padding = (row_height - line_height) / 2
                self.set_xy(x_start, y_start + sl_no_padding)
                self.cell(col_widths[0], line_height, sl_no_text, border=0, align='C')
                self.set_xy(x_start + col_widths[0], y_start)
                self.multi_cell(col_widths[1], line_height, address_text, border=0, align='L')
                pincode_padding = (row_height - line_height) / 2
                self.set_xy(x_start + col_widths[0] + col_widths[1], y_start + pincode_padding)
                self.cell(col_widths[2], line_height, pincode_text, border=0, align='C')
                self.set_y(y_start + row_height)

