        cursor.execute("SELECT s.staff_id, s.staff_name, s.phone, s.status, s.joined_date, l.username FROM staff s JOIN login l ON s.staff_id = l.staff_id WHERE l.role = 'staff' ORDER BY s.joined_date DESC")
