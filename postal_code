    try:
        placeholders = ', '.join(['%s'] * len(item_ids_to_clear))
        query = f"UPDATE parcel SET status = 'dispatched' WHERE parcel_id IN ({placeholders})"
        cursor.execute(query, tuple(item_ids_to_clear))
        conn.commit()
        message = f"Successfully marked {cursor.rowcount} items as dispatched."
        return jsonify({'success': True, 'message': message})
    except Error as e:
        conn.rollback()
        print(f"DATABASE ERROR in clear_bin_session: {e}")
        return jsonify({'success': False, 'message': f'A database error occurred: {e}'}), 500
    finally:
        cursor.close()
        conn.close()

@app.route('/staff/sorted-history')
@login_required
@role_required('staff')
def view_sorted_history():
    conn = get_db_connection()
    if not conn:
        flash('Database service is currently unavailable.', 'danger')
        return redirect(url_for('staff_home'))
    cursor = conn.cursor(dictionary=True)
    items = []
    try:
        staff_id = session.get('staff_id')
        query = """
            SELECT 
                b.bin_name, 
                p.full_address, 
                p.pincode, 
                si.sorted_time
            FROM sorted_item si
            JOIN parcel p ON si.parcel_id = p.parcel_id
            JOIN bin b ON si.bin_id = b.bin_id
            WHERE 
                si.staff_id = %s 
                AND DATE(si.sorted_time) = CURDATE()
            ORDER BY si.sorted_time DESC
        """
        cursor.execute(query, (staff_id,))
        items = cursor.fetchall()
    except Error as e:
        flash(f'An error occurred while fetching sorted history: {e}', 'danger')
    finally:
        cursor.close()
        conn.close()
    return render_template('view_sorted_history.html', items=items)

