    if not isinstance(item_ids_to_clear, list) or not item_ids_to_clear:
        return jsonify({'success': True, 'message': 'No items to clear.'})
    conn = get_db_connection()
    if not conn:
        return jsonify({'success': False, 'message': 'Database service is unavailable.'}), 500
